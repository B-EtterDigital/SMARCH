{
  "product": {
    "media_class": "utility",
    "rationale": "CLI framework + self-hostable dashboard; no generative media in scope (V-13 demo recording is a docs task, not a paid media pipeline).",
    "platforms": [
      "node"
    ]
  },
  "sma": {
    "control_plane": "~/DEV/SMARCH",
    "project_id": "sma"
  },
  "hot_paths": [
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    ".github/workflows/**",
    "tools/sma.mjs",
    "tools/lib/sma-paths.mjs",
    "tools/lib/portfolio-config.mjs",
    "schemas/**",
    "AGENTS.md",
    "README.md",
    ".gitleaks.toml",
    "sma.gen3.json"
  ],
  "modules": [
    {
      "id": "coord",
      "code": "CO",
      "ownership": [
        "tools/sma-lease.mjs",
        "tools/sma-context*.mjs",
        "tools/sma-conflict.mjs",
        "tools/sma-merge.mjs",
        "tools/sma-start-edit.mjs",
        "tools/sma-end-edit.mjs",
        "tools/sma-controller-snapshot.mjs",
        "tools/sma-dirty-baseline.mjs",
        "tools/sma-parallel-preflight.mjs",
        "tools/sma-cleanup-packets.mjs",
        "tools/sma-seed.mjs",
        "tools/lib/context-log.mjs",
        "tools/lib/gen3-state.mjs",
        "tools/lib/parallel-preflight-selftest.mjs",
        "tools/hooks/**"
      ],
      "gates": [
        "npm run gen3:selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "ci"
      ],
      "graph": "graphify-out/modules/coord/graphify-out/graph.json"
    },
    {
      "id": "prov",
      "code": "PR",
      "ownership": [
        "tools/sma-attest*.mjs",
        "tools/sma-provenance-*.mjs",
        "tools/sma-anchor.mjs",
        "tools/lib/merkle*.mjs",
        "tools/lib/license-*.mjs",
        "tools/lib/provenance-seal*.mjs",
        "tools/lib/attestation*.mjs",
        "tools/lib/export-*.mjs",
        "tools/lib/similarity*.mjs",
        "tools/lib/ledger-resolve.mjs",
        "tools/gen-public-ledger.mjs"
      ],
      "gates": [
        "npm run provenance:selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "ci"
      ],
      "graph": "graphify-out/modules/prov/graphify-out/graph.json"
    },
    {
      "id": "reg",
      "code": "RG",
      "ownership": [
        "tools/sma-scan.mjs",
        "tools/sma-state.mjs",
        "tools/sma-merge-registries.mjs",
        "tools/sma-store.mjs",
        "tools/sma-store-remote.mjs",
        "tools/sma-clone*.mjs",
        "tools/sma-release*.mjs",
        "tools/sma-publish*.mjs",
        "tools/sma-promote.mjs",
        "tools/sma-doctor.mjs",
        "tools/sma-why-blocked.mjs",
        "tools/sma-filter.mjs",
        "tools/sma-match.mjs",
        "tools/sma-enrich.mjs",
        "tools/sma-compact.mjs",
        "tools/sma-recommend-builds.mjs",
        "tools/sma-build-*.mjs",
        "tools/sma-manifest-scaffold.mjs",
        "tools/sma-import-verify.mjs",
        "tools/sma-update-plan.mjs",
        "tools/sma-init-project.mjs",
        "tools/sma-bootstrap-manifests.mjs",
        "tools/sma-reuse-receipt.mjs",
        "tools/sma-backlog.mjs",
        "tools/sma-backfill-*.mjs",
        "tools/sma-stats.mjs",
        "tools/sma-goal-progress.mjs",
        "tools/sma-canonicalization.mjs",
        "tools/sma-portfolio-*.mjs",
        "tools/sma-dependents-index.mjs",
        "tools/sma-operator-packet.mjs",
        "tools/sma-module-work-packets.mjs",
        "tools/lib/portfolio-projects.mjs",
        "tools/lib/project-paths.mjs",
        "tools/lib/adoption-utils.mjs",
        "tools/lib/curated-build-utils.mjs",
        "tools/lib/feature-clusters.mjs",
        "tools/lib/source-path-resolver.mjs",
        "tools/lib/stable-generated.mjs",
        "tools/lib/packet-freshness.mjs",
        "tools/lib/module-work-*.mjs",
        "tools/lib/gen3-goal-progress.mjs",
        "tools/lib/controller-action-report.mjs",
        "tools/lib/ownership.mjs",
        "tools/lib/sma-adoption.mjs",
        "tools/sma-propagate.mjs",
        "tools/sma-refresh-manifest-budgets.mjs",
        "tools/sma-repo-queues.mjs",
        "tools/sma-score.mjs",
        "tools/sma-similarity-scan.mjs",
        "tools/sma-stable-generated-selftest.mjs",
        "tools/sma-sup-status.mjs",
        "tools/sma-token-count.mjs",
        "tools/sma-touch-backfill.mjs",
        "tools/sma-wave-monitor.mjs",
        "tools/sma-wave-observe.mjs"
      ],
      "gates": [
        "npm run check"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "prov",
        "gates",
        "rust",
        "ci"
      ],
      "graph": "graphify-out/modules/reg/graphify-out/graph.json"
    },
    {
      "id": "gates",
      "code": "GA",
      "ownership": [
        "tools/sma-rule-gate.mjs",
        "tools/sma-scope-drift.mjs",
        "tools/sma-security-gate.mjs",
        "tools/sma-license-gate.mjs",
        "tools/sma-compliance-gate.mjs",
        "tools/sma-source-size-gate.mjs",
        "tools/sma-validate*.mjs",
        "tools/sma-ci.mjs",
        "tools/lib/compliance-controls.mjs",
        "tools/source-size-baseline.json",
        "tools/sma-gen3-classify.mjs",
        "tools/sma-leak-gate.mjs"
      ],
      "gates": [
        "npm run gate:all"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "ci"
      ],
      "graph": "graphify-out/modules/gates/graphify-out/graph.json"
    },
    {
      "id": "graph",
      "code": "GR",
      "ownership": [
        "tools/sma-graphify.mjs",
        "tools/sma-graph-packets.mjs"
      ],
      "gates": [
        "node tools/sma-graphify.mjs selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "reg",
        "ci",
        "smoa"
      ],
      "graph": "graphify-out/modules/graph/graphify-out/graph.json"
    },
    {
      "id": "mcp",
      "code": "MC",
      "ownership": [
        "tools/mcp/**"
      ],
      "gates": [
        "node tools/mcp/selftest.mjs"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "reg",
        "prov",
        "ci",
        "evals"
      ],
      "graph": "graphify-out/modules/mcp/graphify-out/graph.json"
    },
    {
      "id": "capsule",
      "code": "CP",
      "ownership": [
        "templates/capsule/**",
        "tools/sma-brick-new.mjs",
        "tools/sma-brick-run.mjs",
        "tools/sma-brick-inspect.mjs"
      ],
      "gates": [
        "node tools/sma-brick-run.mjs --selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "reg",
        "gates",
        "ci"
      ],
      "graph": "graphify-out/modules/capsule/graphify-out/graph.json"
    },
    {
      "id": "smoa",
      "code": "SM",
      "ownership": [
        "tools/sma-codex*.mjs",
        "tools/lib/codex-runner.mjs",
        "tools/lib/workforce/**",
        "tools/sma-smoa-token-summary.mjs"
      ],
      "gates": [
        "node tools/sma-codex-profile.mjs selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "reg",
        "ci"
      ],
      "graph": "graphify-out/modules/smoa/graphify-out/graph.json"
    },
    {
      "id": "dash",
      "code": "DA",
      "ownership": [
        "tools/sma-wiki*.mjs",
        "tools/sma-gen3-dashboard.mjs",
        "tools/sma-dashboard-server.mjs",
        "tools/sma-brick-wall-lego.mjs",
        "tools/lib/gen3-renderers.mjs",
        "web/**",
        "tools/lib/dash-api/**"
      ],
      "gates": [
        "node tools/sma-gen3-dashboard.mjs --selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "reg",
        "coord",
        "graph",
        "ci"
      ],
      "graph": "graphify-out/modules/dash/graphify-out/graph.json"
    },
    {
      "id": "skills",
      "code": "SK",
      "ownership": [
        "skills/**",
        "agent-skills/**",
        "tools/install-agent-skills.mjs",
        ".claude-plugin/**"
      ],
      "gates": [
        "node tools/install-agent-skills.mjs --check"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "docs",
        "ci"
      ],
      "graph": "graphify-out/modules/skills/graphify-out/graph.json"
    },
    {
      "id": "schemas",
      "code": "SC",
      "ownership": [
        "schemas/**",
        "tools/lib/schema-types/**"
      ],
      "gates": [
        "npm run validate:gen3 -- all"
      ],
      "lane_default": "shared-hot-path",
      "allowed_deps": [],
      "graph": "graphify-out/modules/schemas/graphify-out/graph.json"
    },
    {
      "id": "docs",
      "code": "DO",
      "ownership": [
        "docs/**",
        "README.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "NOTICE",
        "examples/**",
        "templates/agents/**",
        "templates/project/**",
        "templates/brick/**",
        "SPE/**",
        "SRS/**",
        "SSTF-v1/**",
        "templates/build-verification/**",
        "templates/github/**",
        "templates/security/**"
      ],
      "gates": [
        "npm run source:size:gate"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "evals"
      ],
      "graph": "graphify-out/modules/docs/graphify-out/graph.json"
    },
    {
      "id": "ci",
      "code": "CI",
      "ownership": [
        ".github/**",
        ".gitleaks.toml",
        ".pre-commit-config.yaml",
        "tsconfig.json"
      ],
      "gates": [
        "npm run check"
      ],
      "lane_default": "shared-hot-path",
      "allowed_deps": [
        "rust",
        "skills"
      ],
      "graph": "graphify-out/modules/ci/graphify-out/graph.json"
    },
    {
      "id": "evals",
      "code": "EV",
      "ownership": [
        "tools/evals/**"
      ],
      "gates": [
        "node tools/evals/run.mjs --selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "coord",
        "smoa",
        "ci"
      ],
      "graph": "graphify-out/modules/evals/graphify-out/graph.json"
    },
    {
      "id": "commun",
      "code": "CM",
      "ownership": [
        "docs/community/**",
        "tools/sma-submit.mjs",
        ".github/ISSUE_TEMPLATE/**",
        ".github/DISCUSSION_TEMPLATE/**"
      ],
      "gates": [
        "npm run source:size:gate"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "schemas",
        "reg",
        "prov",
        "gates",
        "ci"
      ],
      "graph": "graphify-out/modules/commun/graphify-out/graph.json"
    },
    {
      "id": "rust",
      "code": "RS",
      "ownership": [
        "rust-core/**"
      ],
      "gates": [
        "cargo test --manifest-path rust-core/Cargo.toml"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "reg"
      ],
      "graph": "graphify-out/modules/rust/graphify-out/graph.json"
    },
    {
      "id": "sync",
      "code": "SY",
      "ownership": [
        "tools/sma-sync-public.mjs",
        "docs/SYNC_RUNBOOK.md"
      ],
      "gates": [
        "node tools/sma-sync-public.mjs --selftest"
      ],
      "lane_default": "single-module",
      "allowed_deps": [
        "gates",
        "reg",
        "ci"
      ],
      "graph": "graphify-out/modules/sync/graphify-out/graph.json"
    }
  ]
}
