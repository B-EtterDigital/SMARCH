{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sweetspot.local/schemas/release.schema.json",
  "title": "Sweetspot Artifact Release",
  "description": "This schema defines a versioned brick release with source identity, compatibility, artifacts, integrity checks, verification, rollout guidance, and provenance. Brick maintainers, consumers, and release tooling need it when they publish or install a reusable version. Read it before cutting a release or deciding whether an update is safe for a dependent project. Remember that release metadata must describe the exact artifacts and evidence shipped under that version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release",
    "content",
    "contracts",
    "verification",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version that this document conforms to.",
      "const": "1.0.0"
    },
    "release": {
      "type": "object",
      "description": "Fields that describe the release.",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "artifact_id",
        "version",
        "channel",
        "status",
        "created_at",
        "source_commit",
        "registry_snapshot_sha",
        "content_hash"
      ],
      "properties": {
        "release_id": {
          "type": "string",
          "description": "Stable identifier of the release associated with this record.",
          "pattern": "^[a-z0-9][a-z0-9._:@-]{2,180}$"
        },
        "artifact_type": {
          "$ref": "#/$defs/artifact_type",
          "description": "Structured value recorded for artifact type."
        },
        "artifact_id": {
          "$ref": "#/$defs/artifact_id",
          "description": "Structured value recorded for artifact identifier."
        },
        "version": {
          "$ref": "#/$defs/semver",
          "description": "Version assigned to the release."
        },
        "channel": {
          "type": "string",
          "description": "Selected channel; allowed values are `dev`, `alpha`, `beta`, `candidate`, `stable`, `lts`, `hotfix`.",
          "enum": [
            "dev",
            "alpha",
            "beta",
            "candidate",
            "stable",
            "lts",
            "hotfix"
          ]
        },
        "status": {
          "type": "string",
          "description": "Current status of the release.",
          "enum": [
            "draft",
            "published",
            "deprecated",
            "yanked",
            "superseded"
          ]
        },
        "source_project": {
          "type": "string",
          "description": "Source project for the release."
        },
        "source_manifest_path": {
          "type": "string",
          "description": "Source manifest path for the release."
        },
        "created_at": {
          "type": "string",
          "description": "Time recorded for created at, in ISO 8601 date-time format.",
          "format": "date-time"
        },
        "published_at": {
          "type": "string",
          "description": "Time recorded for published at, in ISO 8601 date-time format.",
          "format": "date-time"
        },
        "source_commit": {
          "$ref": "#/$defs/hash_like",
          "description": "Structured value recorded for source commit."
        },
        "registry_snapshot_sha": {
          "$ref": "#/$defs/hash_like",
          "description": "SHA-256 digest of the global registry snapshot used to build this index."
        },
        "content_hash": {
          "$ref": "#/$defs/hash_like",
          "description": "Structured value recorded for content hash."
        },
        "previous_release": {
          "type": "string",
          "description": "Previous release for the release."
        },
        "registry_origin": {
          "type": "string",
          "format": "uri",
          "description": "Optional. Identity-portable origin URL. Federation hook for resolving the same release across SMA instances."
        },
        "supersedes": {
          "type": "array",
          "description": "Ordered supersedes values for the release.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "replacement_release": {
          "type": "string",
          "description": "Replacement release for the release."
        },
        "breaking": {
          "type": "boolean",
          "description": "Whether breaking applies to the release."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the release."
        }
      }
    },
    "content": {
      "type": "object",
      "description": "Fields that describe the content.",
      "additionalProperties": false,
      "required": [
        "included_paths"
      ],
      "properties": {
        "included_paths": {
          "type": "array",
          "description": "Ordered included paths values for the content.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "portable_docs": {
          "type": "array",
          "description": "Ordered portable docs values for the content.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "entrypoints": {
          "type": "array",
          "description": "Ordered entrypoints values for the content.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "artifacts": {
          "type": "array",
          "description": "Artifacts produced or referenced by this record.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "kind",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "description": "Repository-relative path to the artifact."
              },
              "kind": {
                "type": "string",
                "description": "Classification assigned to the artifact.",
                "enum": [
                  "file",
                  "directory",
                  "doc",
                  "asset",
                  "config",
                  "migration",
                  "test"
                ]
              },
              "sha256": {
                "$ref": "#/$defs/hash_like",
                "description": "SHA-256 digest used to verify file or artifact integrity."
              },
              "executable": {
                "type": "boolean",
                "description": "Whether executable applies to the items."
              }
            }
          }
        }
      }
    },
    "contracts": {
      "type": "object",
      "description": "Fields that describe the contracts.",
      "additionalProperties": false,
      "required": [
        "hashes",
        "runtimes"
      ],
      "properties": {
        "hashes": {
          "type": "object",
          "description": "Fields that describe the hashes.",
          "additionalProperties": false,
          "properties": {
            "env": {
              "$ref": "#/$defs/hash_like",
              "description": "Structured value recorded for environment."
            },
            "interfaces": {
              "$ref": "#/$defs/hash_like",
              "description": "Structured value recorded for interfaces."
            },
            "data": {
              "$ref": "#/$defs/hash_like",
              "description": "Structured value recorded for data."
            },
            "rls": {
              "$ref": "#/$defs/hash_like",
              "description": "Structured value recorded for row-level security."
            },
            "dependencies": {
              "$ref": "#/$defs/hash_like",
              "description": "Structured value recorded for dependencies."
            },
            "verification": {
              "$ref": "#/$defs/hash_like",
              "description": "Structured value recorded for verification."
            }
          }
        },
        "runtimes": {
          "type": "array",
          "description": "Ordered runtimes values for the contract.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_env": {
          "type": "array",
          "description": "Ordered required environment values for the contract.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "optional_env": {
          "type": "array",
          "description": "Ordered optional environment values for the contract.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "forbidden_env": {
          "type": "array",
          "description": "Ordered forbidden environment values for the contract.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "data_classes": {
          "type": "array",
          "description": "Ordered data classes values for the contract.",
          "items": {
            "type": "string",
            "enum": [
              "public",
              "user_private",
              "org_private",
              "admin_only",
              "pii",
              "payment",
              "credential",
              "health_sensitive",
              "regulated"
            ]
          },
          "uniqueItems": true
        },
        "public_interfaces": {
          "type": "array",
          "description": "Ordered public interfaces values for the contract.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "dependency_refs": {
          "type": "array",
          "description": "Ordered dependency refs values for the contract.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact_type",
              "artifact_id"
            ],
            "properties": {
              "artifact_type": {
                "$ref": "#/$defs/artifact_type",
                "description": "Structured value recorded for artifact type."
              },
              "artifact_id": {
                "$ref": "#/$defs/artifact_id",
                "description": "Structured value recorded for artifact identifier."
              },
              "version_range": {
                "type": "string",
                "description": "Recorded version range for the items."
              },
              "release_ref": {
                "type": "string",
                "description": "Recorded release ref for the items."
              },
              "required": {
                "type": "boolean",
                "description": "Whether required applies to the items."
              }
            }
          }
        },
        "external_packages": {
          "type": "array",
          "description": "Ordered external packages values for the contract.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Human-readable name of the external package."
              },
              "version_range": {
                "type": "string",
                "description": "Recorded version range for the items."
              },
              "scope": {
                "type": "string",
                "description": "Selected scope; allowed values are `runtime`, `build`, `dev`.",
                "enum": [
                  "runtime",
                  "build",
                  "dev"
                ]
              }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "description": "Fields that describe the verification.",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "description": "Current status of the verification.",
          "enum": [
            "unverified",
            "candidate",
            "verified",
            "canonical",
            "failed"
          ]
        },
        "verified_at": {
          "type": "string",
          "description": "Time recorded for verified at, in ISO 8601 date-time format.",
          "format": "date-time"
        },
        "fixture_targets": {
          "type": "array",
          "description": "Ordered fixture targets values for the verification.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "smoke_commands": {
          "type": "array",
          "description": "Ordered smoke commands values for the verification.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "integration_targets": {
          "type": "array",
          "description": "Ordered integration targets values for the verification.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "checks": {
          "type": "array",
          "description": "Ordered checks values for the verification.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Human-readable name of the check."
              },
              "status": {
                "type": "string",
                "description": "Current status of the check.",
                "enum": [
                  "passed",
                  "failed",
                  "skipped"
                ]
              },
              "command": {
                "type": "string",
                "description": "Command used to produce or verify this evidence."
              },
              "evidence_path": {
                "type": "string",
                "description": "Recorded evidence path for the items."
              }
            }
          }
        },
        "rollback_supported": {
          "type": "boolean",
          "description": "Whether rollback supported applies to the verification."
        }
      }
    },
    "migration": {
      "type": "object",
      "description": "Fields that describe the migration.",
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string",
          "description": "Additional notes about the migration."
        },
        "commands": {
          "type": "array",
          "description": "Ordered commands values for the migration.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "manual_steps": {
          "type": "array",
          "description": "Ordered manual steps values for the migration.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "rollback": {
      "type": "object",
      "description": "Fields that describe the rollback.",
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string",
          "description": "Additional notes about the rollback."
        },
        "commands": {
          "type": "array",
          "description": "Ordered commands values for the rollback.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "artifact_paths": {
          "type": "array",
          "description": "Ordered artifact paths values for the rollback.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "provenance": {
      "type": "object",
      "description": "Evidence describing where the content came from and who changed it.",
      "additionalProperties": false,
      "required": [
        "created_by"
      ],
      "properties": {
        "created_by": {
          "$ref": "#/$defs/actor_record",
          "description": "Structured value recorded for created by."
        },
        "reviewed_by": {
          "type": "array",
          "description": "Ordered reviewed by values for the provenance.",
          "items": {
            "$ref": "#/$defs/actor_record"
          }
        },
        "source_chain": {
          "type": "array",
          "description": "Ordered source chain values for the provenance.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "ref"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "description": "Classification assigned to the source chain.",
                "enum": [
                  "manifest",
                  "registry",
                  "build",
                  "brick",
                  "release",
                  "commit",
                  "doc"
                ]
              },
              "ref": {
                "type": "string",
                "description": "Recorded ref for the items."
              },
              "hash": {
                "$ref": "#/$defs/hash_like",
                "description": "Structured value recorded for hash."
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,160}$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "brick",
        "build"
      ]
    },
    "actor_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "description": "Actor for the actor record."
        },
        "tool": {
          "type": "string",
          "description": "Tool for the actor record."
        },
        "model": {
          "type": "string",
          "description": "Model identifier recorded for an AI-driven actor."
        },
        "timestamp": {
          "type": "string",
          "description": "Time when the event occurred, in ISO 8601 date-time format.",
          "format": "date-time"
        }
      }
    },
    "hash_like": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,128}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
