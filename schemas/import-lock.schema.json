{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sweetspot.local/schemas/import-lock.schema.json",
  "title": "Sweetspot Import Lock",
  "description": "This schema defines a project import lock that pins reused bricks to source versions, integrity evidence, and local adaptation state. Project maintainers, update tooling, and release reviewers need it when they install, verify, or upgrade a tracked dependency. Read it before changing a locked source or applying an upstream release. Remember that the lock records the exact source version the project consumed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lock",
    "target",
    "selected_builds",
    "resolved_bricks",
    "frozen_dependency_graph",
    "trust_policy",
    "verification_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version that this document conforms to.",
      "const": "1.0.0"
    },
    "lock": {
      "type": "object",
      "description": "Fields that describe the lock.",
      "additionalProperties": false,
      "required": [
        "generated_at",
        "registry_snapshot_sha",
        "mode"
      ],
      "properties": {
        "lock_id": {
          "type": "string",
          "description": "Lock identifier for the lock.",
          "pattern": "^[a-z0-9][a-z0-9._:@-]{2,180}$"
        },
        "generated_at": {
          "type": "string",
          "description": "Time when this document was generated, in ISO 8601 date-time format.",
          "format": "date-time"
        },
        "generated_by": {
          "$ref": "#/$defs/actor_record",
          "description": "Structured value recorded for generated by."
        },
        "registry_snapshot_sha": {
          "$ref": "#/$defs/hash_like",
          "description": "SHA-256 digest of the global registry snapshot used to build this index."
        },
        "mode": {
          "type": "string",
          "description": "Selected mode; allowed values are `exact`, `channel`, `mixed`.",
          "enum": [
            "exact",
            "channel",
            "mixed"
          ]
        },
        "imports_path": {
          "type": "string",
          "description": "Imports path for the lock."
        },
        "registry_origin": {
          "type": "string",
          "format": "uri",
          "description": "Optional. Identity-portable origin URL of the SMA registry that produced this lock. Federation hook."
        },
        "placements_path": {
          "type": "string",
          "description": "Placements path for the lock."
        },
        "update_journal_path": {
          "type": "string",
          "description": "Update journal path for the lock."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the lock."
        }
      }
    },
    "target": {
      "type": "object",
      "description": "Fields that describe the target.",
      "additionalProperties": false,
      "required": [
        "root"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable identifier of the target."
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of the target."
        },
        "root": {
          "type": "string",
          "description": "Repository root represented by this record."
        },
        "repository": {
          "type": "string",
          "description": "Repository location for the target."
        },
        "commit": {
          "$ref": "#/$defs/hash_like",
          "description": "Git commit identifier associated with the recorded work."
        },
        "runtimes": {
          "type": "array",
          "description": "Ordered runtimes values for the target.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "frameworks": {
          "type": "array",
          "description": "Ordered frameworks values for the target.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "selected_builds": {
      "type": "array",
      "description": "Ordered selected builds values for the record.",
      "items": {
        "$ref": "#/$defs/locked_build"
      }
    },
    "resolved_bricks": {
      "type": "array",
      "description": "Ordered resolved bricks values for the record.",
      "items": {
        "$ref": "#/$defs/locked_brick"
      }
    },
    "channels": {
      "type": "array",
      "description": "Ordered channels values for the record.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_type",
          "artifact_id",
          "channel"
        ],
        "properties": {
          "artifact_type": {
            "$ref": "#/$defs/artifact_type",
            "description": "Structured value recorded for artifact type."
          },
          "artifact_id": {
            "$ref": "#/$defs/artifact_id",
            "description": "Structured value recorded for artifact identifier."
          },
          "channel": {
            "type": "string",
            "description": "Selected channel; allowed values are `dev`, `alpha`, `beta`, `candidate`, `stable`, `lts`, `hotfix`.",
            "enum": [
              "dev",
              "alpha",
              "beta",
              "candidate",
              "stable",
              "lts",
              "hotfix"
            ]
          }
        }
      }
    },
    "frozen_dependency_graph": {
      "type": "object",
      "description": "Fields that describe the frozen dependency graph.",
      "additionalProperties": false,
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "description": "Ordered nodes values for the frozen dependency graph.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "node_id",
              "artifact_type",
              "artifact_id",
              "release_version"
            ],
            "properties": {
              "node_id": {
                "type": "string",
                "description": "Recorded node identifier for the items."
              },
              "artifact_type": {
                "$ref": "#/$defs/artifact_type",
                "description": "Structured value recorded for artifact type."
              },
              "artifact_id": {
                "$ref": "#/$defs/artifact_id",
                "description": "Structured value recorded for artifact identifier."
              },
              "release_version": {
                "$ref": "#/$defs/semver",
                "description": "Structured value recorded for release version."
              },
              "release_hash": {
                "$ref": "#/$defs/hash_like",
                "description": "Structured value recorded for release hash."
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "description": "Ordered edges values for the frozen dependency graph.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "from",
              "to",
              "relation"
            ],
            "properties": {
              "from": {
                "type": "string",
                "description": "Recorded from for the items."
              },
              "to": {
                "type": "string",
                "description": "Recorded to for the items."
              },
              "relation": {
                "type": "string",
                "description": "Selected relation; allowed values are `depends_on`, `composes_with`, `optional`, `adapter_for`, `alternative_to`.",
                "enum": [
                  "depends_on",
                  "composes_with",
                  "optional",
                  "adapter_for",
                  "alternative_to"
                ]
              }
            }
          }
        }
      }
    },
    "trust_policy": {
      "type": "object",
      "description": "Fields that describe the trust policy.",
      "additionalProperties": false,
      "required": [
        "allowed_release_statuses",
        "require_contract_hashes",
        "allow_local_overrides"
      ],
      "properties": {
        "allowed_release_statuses": {
          "type": "array",
          "description": "Ordered allowed release statuses values for the trust policy.",
          "items": {
            "type": "string",
            "enum": [
              "draft",
              "published",
              "deprecated",
              "yanked",
              "superseded"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "minimum_verification_status": {
          "type": "string",
          "description": "Selected minimum verification status; allowed values are `unverified`, `candidate`, `verified`, `canonical`.",
          "enum": [
            "unverified",
            "candidate",
            "verified",
            "canonical"
          ]
        },
        "require_contract_hashes": {
          "type": "boolean",
          "description": "Whether require contract hashes applies to the trust policy."
        },
        "allow_local_overrides": {
          "type": "boolean",
          "description": "Whether allow local overrides applies to the trust policy."
        },
        "fail_on_yanked_release": {
          "type": "boolean",
          "description": "Whether fail on yanked release applies to the trust policy."
        },
        "fail_on_breaking_upgrade": {
          "type": "boolean",
          "description": "Whether fail on breaking upgrade applies to the trust policy."
        }
      }
    },
    "verification_policy": {
      "type": "object",
      "description": "Fields that describe the verification policy.",
      "additionalProperties": false,
      "required": [
        "run_declared_tests",
        "fail_on_missing_env",
        "required_check_status"
      ],
      "properties": {
        "run_declared_tests": {
          "type": "boolean",
          "description": "Whether run declared tests applies to the verification policy."
        },
        "run_import_resolution": {
          "type": "boolean",
          "description": "Whether run import resolution applies to the verification policy."
        },
        "run_env_truthing": {
          "type": "boolean",
          "description": "Whether run environment truthing applies to the verification policy."
        },
        "run_rls_truthing": {
          "type": "boolean",
          "description": "Whether run row-level security truthing applies to the verification policy."
        },
        "fail_on_missing_env": {
          "type": "boolean",
          "description": "Whether fail on missing environment applies to the verification policy."
        },
        "fail_on_contract_delta": {
          "type": "boolean",
          "description": "Whether fail on contract delta applies to the verification policy."
        },
        "required_check_status": {
          "type": "string",
          "description": "Selected required check status; allowed values are `passed`, `warning`, `skipped`.",
          "enum": [
            "passed",
            "warning",
            "skipped"
          ]
        },
        "post_install_checks": {
          "type": "array",
          "description": "Ordered post install checks values for the verification policy.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "actor_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "description": "Actor for the actor record."
        },
        "tool": {
          "type": "string",
          "description": "Tool for the actor record."
        },
        "model": {
          "type": "string",
          "description": "Model identifier recorded for an AI-driven actor."
        }
      }
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,160}$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "brick",
        "build"
      ]
    },
    "hash_like": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,128}$"
    },
    "locked_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "import_id",
        "artifact_type",
        "artifact_id",
        "release_version"
      ],
      "properties": {
        "import_id": {
          "type": "string",
          "description": "Import identifier for the locked artifact.",
          "pattern": "^[a-z0-9][a-z0-9._:@-]{2,180}$"
        },
        "artifact_type": {
          "$ref": "#/$defs/artifact_type",
          "description": "Structured value recorded for artifact type."
        },
        "artifact_id": {
          "$ref": "#/$defs/artifact_id",
          "description": "Structured value recorded for artifact identifier."
        },
        "release_version": {
          "$ref": "#/$defs/semver",
          "description": "Structured value recorded for release version."
        },
        "release_hash": {
          "$ref": "#/$defs/hash_like",
          "description": "Structured value recorded for release hash."
        },
        "channel": {
          "type": "string",
          "description": "Selected channel; allowed values are `dev`, `alpha`, `beta`, `candidate`, `stable`, `lts`, `hotfix`.",
          "enum": [
            "dev",
            "alpha",
            "beta",
            "candidate",
            "stable",
            "lts",
            "hotfix"
          ]
        },
        "source_project": {
          "type": "string",
          "description": "Source project for the locked artifact."
        },
        "trust_tier": {
          "type": "string",
          "description": "Selected trust tier; allowed values are `experimental`, `candidate`, `verified`, `canonical`.",
          "enum": [
            "experimental",
            "candidate",
            "verified",
            "canonical"
          ]
        },
        "verification_status": {
          "type": "string",
          "description": "Selected verification status; allowed values are `unverified`, `candidate`, `verified`, `canonical`, `failed`.",
          "enum": [
            "unverified",
            "candidate",
            "verified",
            "canonical",
            "failed"
          ]
        },
        "local_overrides": {
          "type": "integer",
          "description": "Local overrides as a whole number for the locked artifact.",
          "minimum": 0
        }
      }
    },
    "locked_brick": {
      "allOf": [
        {
          "$ref": "#/$defs/locked_artifact"
        },
        {
          "type": "object",
          "properties": {
            "artifact_type": {
              "const": "brick",
              "description": "Value fixed to \"brick\" by this schema."
            }
          }
        }
      ]
    },
    "locked_build": {
      "allOf": [
        {
          "$ref": "#/$defs/locked_artifact"
        },
        {
          "type": "object",
          "properties": {
            "artifact_type": {
              "const": "build",
              "description": "Value fixed to \"build\" by this schema."
            }
          }
        }
      ]
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
