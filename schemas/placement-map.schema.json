{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sweetspot.local/schemas/placement-map.schema.json",
  "title": "Sweetspot Placement Map",
  "description": "This schema defines where a reusable brick may be placed in a target repository and how its paths, dependencies, adapters, and checks must be mapped. Composer authors, project maintainers, and clone tooling need it before materializing a brick in a new codebase. Read it when selecting a target module or adapting source paths to local conventions. Remember that placement rules keep owned files inside the brick boundary.",
  "x-sma-contract": {
    "version": "1.0.0",
    "change_policy": "Optional additive fields preserve v1 compatibility; required, renamed, or narrowed fields require a new versioned $id and schema_version.",
    "rollback": "Consumers retain the v1 decoder during the compatibility window; rollback drops only additive optional fields and never rewrites immutable or historical evidence.",
    "readers": [
      "import and verification tooling"
    ],
    "writers": [
      "placement tooling"
    ],
    "lifecycle": "Created or regenerated by the listed writer, validated at its consumer boundary, and retained according to docs/SCHEMA_CONTRACTS.md.",
    "retention": "See docs/SCHEMA_CONTRACTS.md for the artifact-specific retention rule.",
    "performance": "Static file contract; database query plans, indexes, and full-scan budgets are not applicable. Validation performance is covered by schema-case selftests."
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "map",
    "target",
    "imports",
    "placements"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version that this document conforms to.",
      "const": "1.0.0"
    },
    "map": {
      "type": "object",
      "description": "Fields that describe the map.",
      "additionalProperties": false,
      "required": [
        "generated_at"
      ],
      "properties": {
        "generated_at": {
          "type": "string",
          "description": "Time when this document was generated, in ISO 8601 date-time format.",
          "format": "date-time"
        },
        "generated_by": {
          "$ref": "#/$defs/actor_record",
          "description": "Structured value recorded for generated by."
        },
        "registry_snapshot_sha": {
          "$ref": "#/$defs/hash_like",
          "description": "SHA-256 digest of the global registry snapshot used to build this index."
        },
        "lockfile_path": {
          "type": "string",
          "description": "Lockfile path for the map."
        },
        "imports_path": {
          "type": "string",
          "description": "Imports path for the map."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the map."
        }
      }
    },
    "target": {
      "type": "object",
      "description": "Fields that describe the target.",
      "additionalProperties": false,
      "required": [
        "root"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable identifier of the target."
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of the target."
        },
        "root": {
          "type": "string",
          "description": "Repository root represented by this record."
        },
        "repository": {
          "type": "string",
          "description": "Repository location for the target."
        },
        "target_runtime": {
          "type": "string",
          "description": "Target runtime for the target."
        }
      }
    },
    "imports": {
      "type": "array",
      "description": "Ordered imports values for the record.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "import_id",
          "artifact_type",
          "artifact_id",
          "release_version"
        ],
        "properties": {
          "import_id": {
            "type": "string",
            "description": "Recorded import identifier for the items.",
            "pattern": "^[a-z0-9][a-z0-9._:@-]{2,180}$"
          },
          "artifact_type": {
            "$ref": "#/$defs/artifact_type",
            "description": "Structured value recorded for artifact type."
          },
          "artifact_id": {
            "$ref": "#/$defs/artifact_id",
            "description": "Structured value recorded for artifact identifier."
          },
          "release_version": {
            "$ref": "#/$defs/semver",
            "description": "Structured value recorded for release version."
          },
          "release_hash": {
            "$ref": "#/$defs/hash_like",
            "description": "Structured value recorded for release hash."
          },
          "imported_at": {
            "type": "string",
            "description": "Time recorded for imported at, in ISO 8601 date-time format.",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "description": "Current status of the import.",
            "enum": [
              "installed",
              "adapted",
              "drifted",
              "disabled",
              "removed"
            ]
          },
          "portable_doc_paths": {
            "type": "array",
            "description": "Ordered portable doc paths values for the import.",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "placements": {
      "type": "array",
      "description": "Ordered placements values for the record.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "placement_id",
          "import_id",
          "kind",
          "source_path",
          "target_path",
          "ownership"
        ],
        "properties": {
          "placement_id": {
            "type": "string",
            "description": "Recorded placement identifier for the items.",
            "pattern": "^[a-z0-9][a-z0-9._:@-]{2,180}$"
          },
          "import_id": {
            "type": "string",
            "description": "Recorded import identifier for the items.",
            "pattern": "^[a-z0-9][a-z0-9._:@-]{2,180}$"
          },
          "kind": {
            "type": "string",
            "description": "Classification assigned to the placement.",
            "enum": [
              "file",
              "directory",
              "doc",
              "asset",
              "config",
              "migration",
              "test"
            ]
          },
          "source_path": {
            "type": "string",
            "description": "Repository-relative source path supplied by the reusable brick."
          },
          "target_path": {
            "type": "string",
            "description": "Repository-relative destination path for the placed file or directory."
          },
          "source_hash": {
            "$ref": "#/$defs/hash_like",
            "description": "Structured value recorded for source hash."
          },
          "target_hash": {
            "$ref": "#/$defs/hash_like",
            "description": "Structured value recorded for target hash."
          },
          "exported_symbols": {
            "type": "array",
            "description": "Ordered exported symbols values for the placement.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "kind"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Human-readable name of the exported symbol."
                },
                "kind": {
                  "type": "string",
                  "description": "Classification assigned to the exported symbol.",
                  "enum": [
                    "function",
                    "class",
                    "type",
                    "component",
                    "hook",
                    "constant",
                    "route",
                    "command",
                    "other"
                  ]
                },
                "source_export": {
                  "type": "string",
                  "description": "Recorded source export for the items."
                },
                "target_local": {
                  "type": "string",
                  "description": "Recorded target local for the items."
                }
              }
            }
          },
          "alias_rewrites": {
            "type": "array",
            "description": "Ordered alias rewrites values for the placement.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "from",
                "to"
              ],
              "properties": {
                "from": {
                  "type": "string",
                  "description": "Recorded from for the items."
                },
                "to": {
                  "type": "string",
                  "description": "Recorded to for the items."
                }
              }
            }
          },
          "env_bindings": {
            "type": "array",
            "description": "Ordered environment bindings values for the placement.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "surface",
                "required"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Human-readable name of the environment binding."
                },
                "surface": {
                  "type": "string",
                  "description": "Selected surface; allowed values are `server`, `client`, `edge`, `worker`, `shared`.",
                  "enum": [
                    "server",
                    "client",
                    "edge",
                    "worker",
                    "shared"
                  ]
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether required applies to the items."
                },
                "bound_to": {
                  "type": "string",
                  "description": "Recorded bound to for the items."
                }
              }
            }
          },
          "adapter_points": {
            "type": "array",
            "description": "Ordered adapter points values for the placement.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "kind",
                "required",
                "status"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Stable identifier of the adapter point."
                },
                "kind": {
                  "type": "string",
                  "description": "Classification assigned to the adapter point.",
                  "enum": [
                    "api",
                    "storage",
                    "auth",
                    "queue",
                    "telemetry",
                    "ui_slot",
                    "event",
                    "config",
                    "other"
                  ]
                },
                "target_path": {
                  "type": "string",
                  "description": "Repository-relative destination path for the placed file or directory."
                },
                "target_symbol": {
                  "type": "string",
                  "description": "Recorded target symbol for the items."
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether required applies to the items."
                },
                "status": {
                  "type": "string",
                  "description": "Current status of the adapter point.",
                  "enum": [
                    "pending",
                    "bound",
                    "customized",
                    "skipped"
                  ]
                }
              }
            }
          },
          "local_overrides": {
            "type": "array",
            "description": "Ordered local overrides values for the placement.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "status"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "description": "Repository-relative path to the local override."
                },
                "kind": {
                  "type": "string",
                  "description": "Classification assigned to the local override.",
                  "enum": [
                    "patch",
                    "wrapper",
                    "rename",
                    "config",
                    "deleted",
                    "other"
                  ]
                },
                "status": {
                  "type": "string",
                  "description": "Current status of the local override.",
                  "enum": [
                    "active",
                    "merged",
                    "stale"
                  ]
                },
                "notes": {
                  "type": "string",
                  "description": "Additional notes about the local override."
                }
              }
            }
          },
          "ownership": {
            "type": "object",
            "description": "Fields that describe the ownership.",
            "additionalProperties": false,
            "required": [
              "mode",
              "replaceable"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "description": "Selected mode; allowed values are `managed`, `adapted`, `forked`, `local`.",
                "enum": [
                  "managed",
                  "adapted",
                  "forked",
                  "local"
                ]
              },
              "owner": {
                "type": "string",
                "description": "Owner for the ownership."
              },
              "replaceable": {
                "type": "boolean",
                "description": "Whether replaceable applies to the ownership."
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "actor_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "description": "Actor for the actor record."
        },
        "tool": {
          "type": "string",
          "description": "Tool for the actor record."
        },
        "model": {
          "type": "string",
          "description": "Model identifier recorded for an AI-driven actor."
        }
      }
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,160}$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "brick",
        "build"
      ]
    },
    "hash_like": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,128}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
