{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sma/schemas/dependents-index.schema.json",
  "title": "SMA Dependents Index",
  "description": "This schema defines the generated reverse index from each source brick to projects that import or copy it. Release operators and propagation tooling need it when a source version changes and downstream owners must be notified. Read it before applying an update fan-out or diagnosing a missing dependent. Remember that locked imports receive actionable plans while copied forks remain owner-controlled.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "sources",
    "dependents",
    "stats"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "description": "Schema version that this document conforms to."
    },
    "generated_at": {
      "type": "string",
      "description": "Time when this document was generated, in ISO 8601 date-time format.",
      "format": "date-time"
    },
    "registry_snapshot_sha": {
      "type": "string",
      "description": "sha256 of the global registry that produced this index"
    },
    "stats": {
      "type": "object",
      "description": "Fields that describe the stats.",
      "properties": {
        "projects_scanned": {
          "type": "integer",
          "description": "Projects scanned as a whole number for the stat."
        },
        "import_locks_found": {
          "type": "integer",
          "description": "Import locks found as a whole number for the stat."
        },
        "reuse_receipts_found": {
          "type": "integer",
          "description": "Reuse receipts found as a whole number for the stat."
        },
        "unique_source_bricks": {
          "type": "integer",
          "description": "Unique source bricks as a whole number for the stat."
        },
        "total_dependent_links": {
          "type": "integer",
          "description": "Total dependent links as a whole number for the stat."
        }
      }
    },
    "sources": {
      "type": "object",
      "description": "Map: source_brick_id → metadata about the canonical brick (latest version, last_release_artifact, replication policy if declared).",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "source_project": {
            "type": "string"
          },
          "source_path": {
            "type": "string"
          },
          "latest_version": {
            "type": "string"
          },
          "latest_release_artifact": {
            "type": "string"
          },
          "replication_policy": {
            "enum": [
              "track-canonical",
              "pin-version",
              "fork-snapshot",
              "manual"
            ]
          },
          "dependent_count": {
            "type": "integer"
          }
        }
      }
    },
    "dependents": {
      "type": "object",
      "description": "Map: source_brick_id → array of dependent records.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "target_project",
            "target_root",
            "evidence_kind"
          ],
          "properties": {
            "target_project": {
              "type": "string"
            },
            "target_root": {
              "type": "string"
            },
            "target_path": {
              "type": "string"
            },
            "target_brick_id": {
              "type": "string"
            },
            "version_imported": {
              "type": "string"
            },
            "source_commit_imported": {
              "type": "string"
            },
            "imported_at": {
              "type": "string",
              "format": "date-time"
            },
            "evidence_kind": {
              "enum": [
                "import-lock",
                "reuse-receipt",
                "provenance-source-chain",
                "manual"
              ],
              "description": "Where this link was discovered. import-lock is most authoritative."
            },
            "evidence_path": {
              "type": "string"
            },
            "drift": {
              "type": "object",
              "description": "Populated when target's copy diverges from source HEAD.",
              "properties": {
                "loc_added": {
                  "type": "integer"
                },
                "loc_removed": {
                  "type": "integer"
                },
                "files_changed": {
                  "type": "integer"
                },
                "last_local_modification": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            },
            "upgrade_status": {
              "enum": [
                "up-to-date",
                "behind-minor",
                "behind-major",
                "diverged",
                "unknown"
              ]
            }
          }
        }
      }
    }
  }
}
