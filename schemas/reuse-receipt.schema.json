{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sma/schemas/reuse-receipt.schema.json",
  "title": "SMA Reuse Receipt",
  "description": "Records what was inherited from one project into another, the token cost saved, and the imperfections that landed in the target project's backlog. Generated by tools/sma-reuse-receipt.mjs whenever a brick or build is cloned via tools/sma-clone.mjs (or manually copied).",
  "type": "object",
  "required": ["schema_version", "id", "generated_at", "source", "target", "items", "estimates"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "id": { "type": "string", "description": "Stable id for this receipt: <target_project>:<source_project>@<commit>:<iso8601>" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["project", "commit"],
      "properties": {
        "project": { "type": "string" },
        "commit": { "type": "string" },
        "registry_path": { "type": "string", "description": "Path to the source SMA scan registry, if available." }
      }
    },
    "target": {
      "type": "object",
      "required": ["project", "root"],
      "properties": {
        "project": { "type": "string" },
        "root": { "type": "string" },
        "commit": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "description": "One entry per inherited brick or build.",
      "items": {
        "type": "object",
        "required": ["source_brick_id", "target_path", "kind", "loc", "files"],
        "properties": {
          "source_brick_id": { "type": "string" },
          "target_brick_id": { "type": "string" },
          "target_path": { "type": "string" },
          "kind": { "enum": ["brick", "build", "service", "module", "component", "hook", "utility", "schema"] },
          "loc": { "type": "integer", "minimum": 0 },
          "files": { "type": "integer", "minimum": 0 },
          "token_estimate": { "type": "integer", "minimum": 0 },
          "modified_after_clone": {
            "type": "object",
            "properties": {
              "loc_added": { "type": "integer" },
              "loc_removed": { "type": "integer" },
              "files_changed": { "type": "integer" }
            }
          }
        }
      }
    },
    "estimates": {
      "type": "object",
      "required": ["loc_inherited_total", "tokens_saved_estimate"],
      "properties": {
        "loc_inherited_total": { "type": "integer" },
        "tokens_saved_estimate": {
          "type": "object",
          "required": ["lower", "upper", "method"],
          "properties": {
            "lower": { "type": "integer" },
            "upper": { "type": "integer" },
            "method": {
              "type": "string",
              "description": "How the estimate was computed (heuristic, BPE-counted, billed-tokens-from-anthropic-receipts, etc.)"
            },
            "factors": {
              "type": "object",
              "description": "Per-factor breakdown: direct_generation, iteration_roundtrips, design_discussion, etc.",
              "additionalProperties": { "type": "integer" }
            }
          }
        },
        "infrastructure_cost_tokens": {
          "type": "integer",
          "description": "Tokens spent in this session to ingest the bricks (read manifests, patch imports, write shims). Net savings = saved - infrastructure."
        },
        "wall_clock_minutes_saved_estimate": { "type": "integer" }
      }
    },
    "backlog_entry_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Backlog ids opened in the TARGET project for imperfections in the inherited bricks (e.g. typecheck disabled, missing types, dependency drift)."
    },
    "provenance": {
      "type": "object",
      "properties": {
        "actor_kind": { "enum": ["human", "ai_model", "automation"] },
        "actor_id": { "type": "string" },
        "model": { "type": "string" },
        "session_id": { "type": "string" }
      }
    }
  }
}
